{
  "name": "@viral-scout/dashboard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "auth:generate": "better-auth generate --output src/db/auth-schema.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react": "^1.1.6",
    "@opennextjs/cloudflare": "^1.19.1",
    "@viral-scout/database": "workspace:*",
    "@viral-scout/types": "workspace:*",
    "@viral-scout/ui": "workspace:*",
    "better-auth": "^1.6.5",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "^7.72.1",
    "recharts": "3.8.0",
    "sonner": "^2.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.11",
    "@viral-scout/eslint-config": "workspace:^",
    "@viral-scout/typescript-config": "workspace:*",
    "@vitejs/plugin-react": "^4.7.0",
    "babel-plugin-react-compiler": "1.0.0",
    "better-sqlite3": "^11.10.0",
    "eslint": "^9.39.4",
    "jsdom": "^26.1.0",
    "sql.js": "^1.14.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.83.0"
  }
}
